import pandas as pd
employees = pd.DataFrame({
    "EmpID": [1, 2, 3, 4],
    "Name": ["Archana", "Ravi", "Priya", "Anita"],
    "Department": ["IT", "HR", "Finance", "IT"]
})

salary = pd.DataFrame({
    "EmpID": [1, 2, 3, 4],
    "Salary": [50000, 45000, 60000, 55000]
})

employees
merged = pd.merge(employees, salary, on="EmpID")

merged
pivot = merged.pivot_table(
    values="Salary",
    index="Department",
    aggfunc="mean"
)

pivot
sales = pd.DataFrame({
    "Month": ["Jan", "Feb"],
    "Laptop": [10, 15],
    "Phone": [20, 25]
})

sales
melted = pd.melt(
    sales,
    id_vars="Month",
    var_name="Product",
    value_name="Quantity"
)

melted
result = (
    merged
    .sort_values("Salary", ascending=False)
    .head(3)
)

result